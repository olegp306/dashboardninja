OPENCLAW_BASE_URL=http://your-openclaw-host:port
OPENCLAW_API_TOKEN=replace-me
MOCK_MODE=true
LIVE_MODE=false

# Optional legacy flag (will be ignored if MOCK_MODE/LIVE_MODE are set).
OPENCLAW_MODE=mock
NEXT_PUBLIC_DASHBOARD_TITLE=Dashboard Ninja

# LLM execution layer (mock vs real OpenAI vs local stub)
LLM_MODE=mock
SIMULATION_MODE=false
AGENT_AUTONOMY=true

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=
OPENAI_TIMEOUT_MS=45000

# Optional model split (falls back to OPENAI_MODEL)
WORKER_MODEL=gpt-4.1-mini
SUPERVISOR_MODEL=gpt-4.1

# Safety / cost controls
TOKEN_BUDGET_PER_TICK=25000
MAX_STEPS_PER_TASK=12
LLM_MAX_RESPONSE_CHARS=12000
LLM_DEBOUNCE_MS=750

# Local inference (stub provider; not implemented yet)
LOCAL_LLM_ENABLED=false

